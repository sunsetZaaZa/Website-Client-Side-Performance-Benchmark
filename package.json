{
  "name": "k6-playwright-performance-capture",
  "version": "0.9.0",
  "private": true,
  "description": "TypeScript-based performance test system using k6 for load generation and Playwright for browser capture.",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:k6": "esbuild src/k6/load-test.ts --bundle --platform=neutral --format=esm --external:k6 --external:k6/http --outfile=dist/k6/load-test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test -r ts-node/register test/*.test.ts",
    "test:perf": "npm run build:k6 && ts-node src/orchestrator/run-test.ts",
    "report": "ts-node src/reporting/report-generator.ts",
    "clean": "rimraf dist results/run-*",
    "verify:deps": "node scripts/check-local-bins.cjs",
    "ci:install": "node scripts/ci-install.cjs && npm run verify:deps",
    "validate:config": "ts-node src/tools/validate-config.ts",
    "k6:run": "node -e \"require('fs').mkdirSync('./results',{recursive:true})\" && npm run build:k6 && k6 run -e TEST_CONFIG_PATH=./config/test-config.json -e K6_SUMMARY_PATH=./results/k6-summary.json dist/k6/load-test.js",
    "k6:inspect": "npm run build:k6 && node -e \"console.log(require('fs').readFileSync('dist/k6/load-test.js','utf8').slice(0,1200))\"",
    "playwright:capture": "ts-node src/tools/capture-pages.ts",
    "test:perf:no-k6": "npm run build:k6 && ts-node src/orchestrator/run-test.ts --skip-k6",
    "test:perf:k6-only": "npm run build:k6 && ts-node src/orchestrator/run-test.ts --skip-browser",
    "orchestrator:run": "ts-node src/orchestrator/run-test.ts",
    "test:perf:thresholds": "npm run build:k6 && ts-node src/orchestrator/run-test.ts --skip-k6",
    "report:latest": "ts-node src/reporting/report-generator.ts",
    "test:perf:report": "npm run test:perf:no-k6 && npm run report",
    "docker:build": "docker compose build perf-runner",
    "docker:run": "docker compose run --build --rm perf-runner",
    "docker:run:no-k6": "docker compose --profile tools run --build --rm perf-runner-no-k6",
    "docker:validate": "docker compose --profile tools run --build --rm validate-config",
    "ci:verify": "node scripts/ci-verify.cjs",
    "ci:perf": "npm run test:perf",
    "ci:perf:docker": "docker compose run --build --rm perf-runner",
    "ci:perf:docker:build": "docker compose build perf-runner"
  },
  "keywords": [
    "k6",
    "playwright",
    "performance",
    "load-testing",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^20.12.12",
    "esbuild": "^0.21.5",
    "playwright": "^1.44.1",
    "rimraf": "^5.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10.9.2 <11"
  }
}
